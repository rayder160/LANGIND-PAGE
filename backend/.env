SECRET_KEY=proxdeep_super_secret_key_12345
DATABASE_URL=sqlite+aiosqlite:///./proxdeep.db

# ==========================================
# CONFIGURACIÓN DEL LLM (PROVEEDOR REAL)
# ==========================================
# Selecciona tu proveedor descomentando la sección correspondiente.

# -----------------
# OPCIÓN 1: OPENAI (Por defecto si pones "sk-...")
# -----------------
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-tu-api-key-de-openai
# LLM_MODEL=gpt-4o
# LLM_FALLBACK=gpt-4o-mini

# -----------------
# OPCIÓN 2: GEMINI (Nativo)
# -----------------
# LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/models/
# LLM_API_KEY=AIzaSy...tu-api-key-de-gemini
# LLM_MODEL=gemini-1.5-pro-latest
# LLM_FALLBACK=gemini-1.5-flash-latest

# -----------------
# OPCIÓN 3: OLLAMA (Local - Era la configuración del proyecto viejo)
# -----------------
LLM_API_URL=http://localhost:11434/v1/chat/completions
LLM_API_KEY=ollama
LLM_MODEL=gemma3:4b
LLM_FALLBACK=llama3.2:3b

# ==========================================
# CONFIGURACIONES COGNITIVAS (CME)
# ==========================================
CME_ENABLE_AGENT_IDENTITY=true
CME_IDENTITY_DEFAULT_NAME=ProxDeep
